<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shortcuts"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a toggle to open its settings."
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        <ImageView
            android:id="@+id/iconWifi"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_wifi"
            android:contentDescription="Wi-Fi state" />
        <Switch
            android:id="@+id/switchWifi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Wi-Fi" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        <ImageView
            android:id="@+id/iconBluetooth"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_bluetooth"
            android:contentDescription="Bluetooth state" />
        <Switch
            android:id="@+id/switchBluetooth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bluetooth" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        <ImageView
            android:id="@+id/iconCellular"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_cellular"
            android:contentDescription="Cellular state" />
        <Switch
            android:id="@+id/switchCellular"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cellular Data" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">
        <ImageView
            android:id="@+id/iconAirplane"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_airplane"
            android:contentDescription="Airplane mode state" />
        <Switch
            android:id="@+id/switchAirplane"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Airplane Mode" />
    </LinearLayout>

</LinearLayout>
