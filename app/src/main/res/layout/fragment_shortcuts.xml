<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:alignmentMode="alignMargins"
    android:rowCount="2"
    android:columnCount="4"
    android:useDefaultMargins="true"
    android:gravity="center">

    <ImageView
        android:id="@+id/iconWifi"
        style="@style/ShortcutIconBase"
        android:layout_row="0"
        android:layout_column="0"
        android:src="@drawable/wifi_enabled"
        android:contentDescription="Wi-Fi state" />

    <ImageView
        android:id="@+id/iconBluetooth"
        style="@style/ShortcutIconBase"
        android:layout_row="0"
        android:layout_column="1"
        android:src="@drawable/bluetooth_enabled"
        android:contentDescription="Bluetooth state" />

    <ImageView
        android:id="@+id/iconCellular"
        style="@style/ShortcutIconBase"
        android:layout_row="0"
        android:layout_column="2"
        android:src="@drawable/cell_data"
        android:contentDescription="Cellular state" />

    <ImageView
        android:id="@+id/iconAirplane"
        style="@style/ShortcutIconBase"
        android:layout_row="0"
        android:layout_column="3"
        android:src="@drawable/airplanemode_active"
        android:contentDescription="Airplane mode state" />

    <!-- Add 4 more icons or empty views for the second row if needed -->
    <View android:layout_row="1" android:layout_column="0" android:layout_width="64dp" android:layout_height="64dp" />
    <View android:layout_row="1" android:layout_column="1" android:layout_width="64dp" android:layout_height="64dp" />
    <View android:layout_row="1" android:layout_column="2" android:layout_width="64dp" android:layout_height="64dp" />
    <View android:layout_row="1" android:layout_column="3" android:layout_width="64dp" android:layout_height="64dp" />

</GridLayout>
