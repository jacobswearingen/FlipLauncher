<resources>
    <style name="Theme.FlipLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
    </style>
    <style name="ShortcutIconBase">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:adjustViewBounds">true</item>
    </style>
    <style name="ShortcutIconEnabled" parent="ShortcutIconBase">
        <item name="android:tint">#2196F3</item>
    </style>
    <style name="ShortcutIconDisabled" parent="ShortcutIconBase">
        <item name="android:tint">#BDBDBD</item>
    </style>
    <style name="MainText">
        <item name="android:textColor">#FFFFFF</item>
    </style>
    <style name="NotificationText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
    <style name="NotificationTimestamp">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>